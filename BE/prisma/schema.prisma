generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}





model User {
  id       Int      @id @default(autoincrement())
  uname    String
  email    String   @unique
  password String
  country  String
  state    String
  city     String
  role     String   @default("user")
  tasks    Task[]
}

model Task {
  id          Int     @id @default(autoincrement())
  title       String
  description String
  status      String   @default("pending")
  user_id     Int
  user        User     @relation(fields: [user_id], references: [id])
}

model RefreshToken {
  id         String        @id @default(uuid())
}